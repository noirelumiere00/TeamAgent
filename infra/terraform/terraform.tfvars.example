# ============================================================
# TeamAgent v3.0 — Terraform 変数値テンプレート
# ============================================================
# cp terraform.tfvars.example terraform.tfvars
# して値を埋めてから terraform plan / apply
# ============================================================

aws_region   = "ap-northeast-1"
environment  = "dev"
project_name = "teamagent"

# RDS
db_instance_class    = "db.t4g.medium"   # dev / PoC 用
db_allocated_storage = 50
db_engine_version    = "16.4"
db_username          = "teamagent"
db_name              = "teamagent"
db_multi_az          = false             # 本番 = true 推奨

# Lambda / Bedrock
bedrock_model_id   = "anthropic.claude-sonnet-4-6-20250719-v1:0"
lambda_memory_size = 1024
lambda_timeout     = 300
