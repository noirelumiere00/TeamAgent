# ============================================================
# TeamAgent v3.0 — 環境変数テンプレート
# ============================================================
# このファイルを `.env` にコピーして実値を入れてください。
# `.env` は .gitignore で除外されます。本番は AWS Secrets Manager 推奨。
# ============================================================

# --- アプリケーション全般 ---
APP_ENV=local                    # local | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# --- Claude Agent SDK / Bedrock ---
# Option A: Anthropic API 直接利用
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B: AWS Bedrock 経由（推奨：本番）
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=                  # IAM Role 利用時は不要
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6-20250719-v1:0

# --- Gemini API（機能④動画分析専用）---
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL_ID=gemini-2.5-flash

# --- pgvector / PostgreSQL ---
DATABASE_URL=postgresql://teamagent:teamagent@localhost:5432/teamagent
PGVECTOR_DIMENSIONS=1024
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0   # or voyage-3, text-embedding-3-large

# --- Slack 連携 ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-1-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_WORKSPACE_ID=Txxxxxxxxx

# --- Google OAuth（Gmail / Drive 共通）---
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback
# Domain-wide delegation を使う場合：
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./secrets/service-account.json
GOOGLE_WORKSPACE_DOMAIN=example.co.jp

# --- 外部スクレイピング系（Phase 4 以降）---
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DPRO_API_KEY=                       # 動画広告プロ（要確認）
BUZZMIRU_API_KEY=                   # Buzzmiru（要確認）

# --- Storage / S3 ---
S3_BUCKET_PROPOSALS=teamagent-proposals
S3_BUCKET_VIDEOS=teamagent-videos
S3_BUCKET_RAW_FILES=teamagent-raw

# --- フィーチャーフラグ ---
FEATURE_GMAIL_INGEST=true
FEATURE_DRIVE_INGEST=true
FEATURE_SLACK_INGEST=true
FEATURE_VIDEO_ANALYSIS=false
FEATURE_PROPOSAL_GEN=false

# --- 監視 / 監査ログ ---
CLOUDWATCH_LOG_GROUP=/teamagent/app
SENTRY_DSN=                          # 任意

# --- レート制限・チューニング ---
GMAIL_INGEST_RATE_LIMIT=250           # 1ユーザー/秒
DRIVE_INGEST_RATE_LIMIT=100
EMBEDDING_BATCH_SIZE=32
AGENT_LOOP_MAX_ITERATIONS=20
